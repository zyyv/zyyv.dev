{
  "name": "zyyv.dev",
  "private": true,
  "description": "Chris' blog built with Nuxt and Vue.",
  "keywords": [
    "blog",
    "nuxt",
    "unocss",
    "vue"
  ],
  "homepage": "https://github.com/zyyv/zyyv.dev#readme",
  "bugs": {
    "url": "https://github.com/zyyv/zyyv.dev/issues"
  },
  "author": "Chris <https://github.com/zyyv>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyyv/zyyv.dev.git"
  },
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt .",
    "format": "oxfmt .",
    "prepare:photos": "pnpm compress && pnpm photos",
    "typecheck": "nuxt typecheck",
    "taze": "taze major -wIr",
    "photos": "esno scripts/photo.ts",
    "compress": "esno scripts/squoosh.ts"
  },
  "dependencies": {
    "@lhlyu/vue-virtual-waterfall": "^1.0.9",
    "@nuxt/content": "^3.15.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "better-sqlite3": "^12.11.1",
    "blurhash": "^2.0.5",
    "dayjs": "^1.11.21",
    "nuxt": "^4.4.8",
    "octokit": "^5.0.5",
    "ripplable": "^0.2.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@iconify-json/catppuccin": "^1.2.17",
    "@iconify-json/fluent-emoji": "^1.2.7",
    "@iconify-json/hugeicons": "^1.2.29",
    "@iconify-json/logos": "^1.2.11",
    "@iconify/utils": "^3.1.3",
    "@octokit/types": "^16.0.0",
    "@types/node": "^25.9.2",
    "@unocss/core": "^66.7.5",
    "@unocss/nuxt": "^66.7.5",
    "esno": "^4.8.0",
    "execa": "^9.6.1",
    "exifr": "^7.1.3",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "squoosh-next": "^0.1.3",
    "taze": "^19.14.1",
    "typescript": "6.0.3",
    "unocss": "^66.7.5",
    "unocss-preset-zyyv": "^2.0.2",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.98.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@11.5.2"
}
