{
  "name": "zyyv.dev",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "description": "Chris' blog built with Astro.",
  "author": "Chris <https://github.com/zyyv>",
  "homepage": "https://github.com/zyyv/zyyv.dev#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyyv/zyyv.dev.git"
  },
  "bugs": {
    "url": "https://github.com/zyyv/zyyv.dev/issues"
  },
  "keywords": [
    "blog",
    "vue",
    "astro",
    "unocss"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro dev",
    "lint": "eslint .",
    "prepare:photos": "pnpm compress && pnpm photos",
    "typecheck": "astro check && tsc --noEmit",
    "taze": "taze major -wIr",
    "photos": "esno scripts/photo.ts",
    "compress": "esno scripts/squoosh.ts"
  },
  "dependencies": {
    "@astrojs/vue": "^6.0.1",
    "@lhlyu/vue-virtual-waterfall": "^1.0.9",
    "blurhash": "^2.0.5",
    "dayjs": "^1.11.20",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/netlify": "^7.0.9",
    "@iconify-json/catppuccin": "^1.2.17",
    "@iconify-json/fluent-emoji": "^1.2.7",
    "@iconify-json/hugeicons": "^1.2.28",
    "@iconify-json/logos": "^1.2.11",
    "@iconify/utils": "^3.1.3",
    "@octokit/types": "^16.0.0",
    "@types/node": "^24.10.0",
    "@unocss/core": "^66.6.8",
    "@vueuse/core": "^14.3.0",
    "astro": "^6.3.3",
    "eslint": "^10.4.0",
    "esno": "^4.8.0",
    "execa": "^9.6.1",
    "exifr": "^7.1.3",
    "lint-staged": "^17.0.5",
    "octokit": "^5.0.5",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "squoosh-next": "^0.1.3",
    "taze": "^19.12.0",
    "typescript": "5.7.2",
    "unocss": "^66.6.8",
    "unocss-preset-zyyv": "^2.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.3.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md}": [
      "eslint --cache --fix"
    ]
  }
}
