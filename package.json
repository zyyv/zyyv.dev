{
  "name": "zyyv.dev",
  "private": true,
  "description": "Chris' blog built with Astro.",
  "keywords": [
    "astro",
    "blog",
    "unocss",
    "vue"
  ],
  "homepage": "https://github.com/zyyv/zyyv.dev#readme",
  "bugs": {
    "url": "https://github.com/zyyv/zyyv.dev/issues"
  },
  "author": "Chris <https://github.com/zyyv>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyyv/zyyv.dev.git"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro dev",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt .",
    "format": "oxfmt .",
    "prepare:photos": "pnpm compress && pnpm photos",
    "typecheck": "astro check && tsc --noEmit",
    "taze": "taze major -wIr",
    "photos": "esno scripts/photo.ts",
    "compress": "esno scripts/squoosh.ts"
  },
  "dependencies": {
    "@astrojs/vue": "^6.0.1",
    "@lhlyu/vue-virtual-waterfall": "^1.0.9",
    "blurhash": "^2.0.5",
    "dayjs": "^1.11.21",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.6.1",
    "@iconify-json/catppuccin": "^1.2.17",
    "@iconify-json/fluent-emoji": "^1.2.7",
    "@iconify-json/hugeicons": "^1.2.29",
    "@iconify-json/logos": "^1.2.11",
    "@iconify/utils": "^3.1.3",
    "@octokit/types": "^16.0.0",
    "@types/node": "^25.9.2",
    "@unocss/core": "^66.7.0",
    "@vueuse/core": "^14.3.0",
    "astro": "^6.4.4",
    "esno": "^4.8.0",
    "execa": "^9.6.1",
    "exifr": "^7.1.3",
    "lint-staged": "^17.0.7",
    "octokit": "^5.0.5",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "squoosh-next": "^0.1.3",
    "taze": "^19.14.1",
    "typescript": "6.0.3",
    "unocss": "^66.7.0",
    "unocss-preset-zyyv": "^2.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@11.5.2"
}
