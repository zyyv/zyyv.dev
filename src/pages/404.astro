---
import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from '../i18n/utils'
import Layout from '../layouts/Layout.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<Layout title={t('notFound.title')}>
  <main class="fade-in-up px-6 py-16 flex flex-1 flex-col items-center justify-center">
    <h1 class="text-8xl text-stone-200 font-bold font-sans dark:text-stone-800">
      404
    </h1>
    <p class="text-lg text-stone-600 mt-4 dark:text-stone-400">
      {t('notFound.description')}
    </p>
    <a
      href={translatePath('/')}
      class="text-sm text-white font-medium mt-8 px-6 py-2.5 rounded-lg bg-stone-800 transition-colors duration-200 dark:text-stone-900 dark:bg-stone-200 hover:bg-stone-700 dark:hover:bg-stone-300"
    >
      {t('notFound.backHome')}
    </a>
  </main>
</Layout>
