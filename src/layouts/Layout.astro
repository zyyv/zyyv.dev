---
import NavHeader from '../../app/components/nav/NavHeader.vue'
import CommandPalette from '../../app/components/command/CommandPalette.vue'
import 'uno.css'
import '../../app/styles/vars.css'
import '../../app/styles/fonts.css'
import '../../app/styles/prose.css'
import '../../app/styles/main.css'

interface Props {
  title?: string
  description?: string
  image?: string
  type?: 'website' | 'article'
  publishedTime?: string
  tags?: string[]
  lang?: string
}

const {
  title = 'Chris',
  description = 'Regardless of the past, do not ask the future.',
  image,
  type = 'website',
  publishedTime,
  tags = [],
  lang = 'en',
} = Astro.props

const ogUrl = 'https://zyyv.dev/'
const canonicalUrl = new URL(Astro.url.pathname, ogUrl).toString()
const ogImage = image ?? `${ogUrl}og.png#1`
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
    <meta name="author" content="Chris" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Chris, Blog, Portfolio" />
    <meta name="theme-color" content="#3c3c43" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === 'article' && tags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@chris_zyyv" />
    <meta name="twitter:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/avatar.png" />
    <title>{title}</title>
    <script is:inline>
      const mode = localStorage.getItem('vueuse-color-scheme') || 'auto'
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
      document.documentElement.classList.toggle('dark', mode === 'dark' || (mode === 'auto' && prefersDark))
    </script>
  </head>
  <body>
    <NavHeader client:load />
    <main>
      <slot />
    </main>
    <CommandPalette client:idle />
  </body>
</html>
