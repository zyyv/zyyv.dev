---
import OriginController from '../components/OriginController.vue'
import Quadrant from '../components/Quadrant.vue'
interface Props {
	title: string
	description?: string
}

const { title, description = "zyyv's personal website" } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script>
			const savedTheme = localStorage.getItem('theme')
			const isDark = savedTheme ? savedTheme === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches

			if (isDark) {
				document.documentElement.classList.add('dark')
			}

			// Check if the browser supports View Transitions API
			if (!document.startViewTransition) {
				// Add a polyfill or fallback if needed
				document.startViewTransition = (callback) => {
					const transition: ViewTransition = {
						finished: Promise.resolve(),
						ready: Promise.resolve(),
						updateCallbackDone: Promise.resolve(),
						skipTransition: () => {},
						types: new Set(),
					}
					callback?.()
					return transition
				}
			}
		</script>
		<meta name="view-transition" content="same-origin" />
	</head>
	<body class="bg-gray-100 dark:bg-gray-900 dark:text-gray-100 min-h-screen transition-colors duration-500 m-0 p-0">
		<div id="quadrant-root" class="w-screen h-screen relative overflow-hidden">
			<!-- Vue 控制器，绝对定位覆盖在四象限上 -->
			<div class="absolute inset-0 z-20 pointer-events-none">
				<OriginController class="w-full h-full" client:only="vue" />
			</div>
			<!-- 四象限布局 -->
			<Quadrant client:only="vue">
				<!-- 左上象限 -->
				<section class="p-4 overflow-auto">
					<slot name="quadrant-top-left">
						<!-- 默认左上象限内容 -->
					</slot>
				</section>
				<!-- 右上象限 -->
				<section class="p-4 overflow-auto">
					<slot name="quadrant-top-right">
						<!-- 默认右上象限内容 -->
					</slot>
				</section>
				<!-- 左下象限 -->
				<section class="p-4 overflow-auto">
					<slot name="quadrant-bottom-left">
						<!-- 默认左下象限内容 -->
					</slot>
				</section>
				<!-- 右下象限 -->
				<section class="p-4 overflow-auto">
					<slot name="quadrant-bottom-right">
						<!-- 默认右下象限内容 -->
					</slot>
				</section>
			</Quadrant>
		</div>
	</body>
</html>

<style is:global>
