		background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMCIgaGVpZ2h0PSIxMCIgZmlsbD0ibm9uZSIgdmlld0JveD0iMCAwIDEwIDEwIj4KICA8Y2lyY2xlIGN4PSI1IiBjeT0iNSIgcj0iMSIgZmlsbD0iI2NjYyIvPgo8L3N2Zz4=');
		background-repeat: repeat;
	}

	.dark body {
		background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMCIgaGVpZ2h0PSIxMCIgZmlsbD0ibm9uZSIgdmlld0JveD0iMCAwIDEwIDEwIj4KICA8Y2lyY2xlIGN4PSI1IiBjeT0iNSIgcj0iMSIgZmlsbD0iIzQ0NCIvPgo8L3N2Zz4=');
	} */

	/* Page content animations */
	::view-transition-group(page) {
		animation-duration: 0.5s;
	}

	#theme-background {
		view-transition-name: background;
	}

	/* Customize the page transition timing */
	::view-transition-old(page),
	::view-transition-new(page) {
		animation: 300ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* Customize background transition */
	::view-transition-group(background) {
		animation-duration: 1s;
		animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* Supporting dark theme */
	.dark ::view-transition-group(root) {
		animation-duration: 0.5s;
	}

	main {
		view-transition-name: page;
	}
</style>
